# Copy this file to ".env" and fill in values as needed.
# The real ".env" file is gitignored — never commit secrets.

# Port the local server listens on (optional, defaults to 3000).
PORT=3000

# Database connection.
# LEAVE THIS BLANK / UNSET for local development — the app will use a local
# SQLite file (data/todo.db) automatically, with zero setup.
#
# For cloud deployment (e.g. Vercel + Neon Postgres), set this to your Postgres
# connection string. When DATABASE_URL is present, the app uses Postgres instead
# of SQLite. Example (from your Neon dashboard):
# DATABASE_URL=postgresql://user:password@your-host.neon.tech/dbname?sslmode=require
DATABASE_URL=
